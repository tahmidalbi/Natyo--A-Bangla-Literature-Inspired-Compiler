prostabona

shonkhya a = 5;
purnoshonkhya b = 3.14;

shobdo a;
shobdo b;

jodi (a > 2)
    shobdo a;
onnotha
    shobdo b;

chokro (a = 0; a < 3; a = a + 1)
    shobdo a;

shobdo shakti(2, 3);
shobdo borgomul(25);

shobdo PAI;
shobdo E;
shobdo G;

uposhonghar
drissho$$ single-line comment

prostabona

shonkhya a = 5;
purnoshonkhya b = 3.14;
bakkyo msg = "Hello Natyo";
okkhyor c = 'A';

drissho jog(x, y)
    pherot x + y;

shobdo a;
shobdo b;
shobdo msg;
shobdo c;

shobdo shakti(2, 3);
shobdo borgomul(25);

