Grammar

    0 $accept: program $end

    1 program: PROSTABONA global_items UPOSHONGHAR

    2 global_items: /* empty */
    3             | global_items global_item

    4 global_item: statement
    5            | function_definition

    6 function_definition: DRISSHO IDENTIFIER LPAREN parameter_list_opt RPAREN block

    7 parameter_list_opt: /* empty */
    8                   | parameter_list

    9 parameter_list: IDENTIFIER
   10               | parameter_list COMMA IDENTIFIER

   11 block: SHURU statement_list SHESH

   12 statement_list: /* empty */
   13               | statement_list statement

   14 statement: declaration SEMICOLON
   15          | assignment SEMICOLON
   16          | print_stmt SEMICOLON
   17          | input_stmt SEMICOLON
   18          | function_call SEMICOLON
   19          | return_stmt SEMICOLON
   20          | if_stmt
   21          | loop_stmt
   22          | block

   23 declaration: SHONKHYA numeric_declarator_list
   24            | PURNOSHONKHYA numeric_declarator_list
   25            | BAKKYO string_declarator_list
   26            | OKKHYOR char_declarator_list

   27 numeric_declarator_list: numeric_declarator
   28                        | numeric_declarator_list COMMA numeric_declarator

   29 numeric_declarator: IDENTIFIER
   30                   | IDENTIFIER ASSIGN expression

   31 string_declarator_list: string_declarator
   32                       | string_declarator_list COMMA string_declarator

   33 string_declarator: IDENTIFIER
   34                  | IDENTIFIER ASSIGN STRING_LITERAL

   35 char_declarator_list: char_declarator
   36                     | char_declarator_list COMMA char_declarator

   37 char_declarator: IDENTIFIER
   38                | IDENTIFIER ASSIGN CHAR_LITERAL

   39 assignment: IDENTIFIER ASSIGN expression
   40           | IDENTIFIER ASSIGN STRING_LITERAL
   41           | IDENTIFIER ASSIGN CHAR_LITERAL

   42 print_stmt: SHOBDO printable

   43 printable: expression
   44          | STRING_LITERAL
   45          | CHAR_LITERAL

   46 input_stmt: JOBDO IDENTIFIER

   47 return_stmt: PHEROT expression
   48            | PHEROT STRING_LITERAL
   49            | PHEROT CHAR_LITERAL

   50 if_stmt: JODI LPAREN condition RPAREN statement
   51        | JODI LPAREN condition RPAREN statement ONNOTHA statement

   52 loop_stmt: CHOKRO LPAREN assignment SEMICOLON condition SEMICOLON assignment RPAREN statement

   53 function_call: IDENTIFIER LPAREN argument_list_opt RPAREN

   54 argument_list_opt: /* empty */
   55                  | argument_list

   56 argument_list: argument
   57              | argument_list COMMA argument

   58 argument: expression
   59         | STRING_LITERAL
   60         | CHAR_LITERAL

   61 condition: expression GT expression
   62          | expression LT expression
   63          | expression GEQ expression
   64          | expression LEQ expression
   65          | expression EQ expression
   66          | expression NEQ expression

   67 expression: expression PLUS expression
   68           | expression MINUS expression
   69           | expression MULT expression
   70           | expression DIV expression
   71           | expression MOD expression
   72           | MINUS expression
   73           | LPAREN expression RPAREN
   74           | SHAKTI LPAREN expression COMMA expression RPAREN
   75           | BORGOMUL LPAREN expression RPAREN
   76           | function_call
   77           | INT_LITERAL
   78           | FLOAT_LITERAL
   79           | IDENTIFIER


